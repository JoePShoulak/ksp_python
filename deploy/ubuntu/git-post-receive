#!/usr/bin/env bash
set -Eeuo pipefail

APP_DIR="${APP_DIR:-/opt/ksp-control-panel/app}"
DEPLOY_BRANCH="${DEPLOY_BRANCH:-main}"
GIT_DIR="${GIT_DIR:-$(pwd)}"

while read -r oldrev newrev refname; do
  branch="${refname#refs/heads/}"

  if [[ "$branch" != "$DEPLOY_BRANCH" ]]; then
    echo "Ignoring $refname; deploy branch is $DEPLOY_BRANCH."
    continue
  fi

  echo "Deploying $newrev to $APP_DIR"
  mkdir -p "$APP_DIR"
  git --work-tree="$APP_DIR" --git-dir="$GIT_DIR" checkout -f "$DEPLOY_BRANCH"
  cd "$APP_DIR"
  bash deploy/ubuntu/deploy.sh
done

[Unit]
Description=KSP Control Panel backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ksp
Group=ksp
WorkingDirectory=/opt/ksp-control-panel/app/backend
EnvironmentFile=-/etc/ksp-control-panel.env
EnvironmentFile=-/opt/ksp-control-panel/app/.runtime.env
ExecStart=/opt/ksp-control-panel/venv/bin/python main.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target

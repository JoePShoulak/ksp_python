# Camera stream settings for HullcamVDS/JRTI integration.
#
# Replace this with the URL JRTI exposes for its camera output. The dashboard
# supports these placeholders: {camera_id}, {camera_index}, {part_name}.
KSP_CAMERA_STREAM_URL=http://192.168.20.104:8080/

# Use "image" for an MJPEG/image stream URL, or "iframe" for a player page.
KSP_CAMERA_STREAM_KIND=iframe
KSP_CAMERA_PUBLIC_PATH_PREFIX=/jrti

# kRPC connection target. In production this app runs on 192.168.20.105 and
# connects to the KSP/kRPC machine shown in-game at 192.168.20.104.
KRPC_ADDRESS=192.168.20.104
KRPC_RPC_PORT=50000
KRPC_STREAM_PORT=50001

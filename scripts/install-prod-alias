#!/usr/bin/env bash
set -Eeuo pipefail

ALIAS_LINE="alias kprod='bash /c/Users/joeps/coding/ksp_python/scripts/prod'"
BASHRC="${HOME}/.bashrc"

touch "$BASHRC"

if grep -Fqx "$ALIAS_LINE" "$BASHRC"; then
  echo "kprod alias is already installed."
else
  {
    echo
    echo "# KSP production helper"
    echo "$ALIAS_LINE"
  } >>"$BASHRC"
  echo "Installed kprod alias in $BASHRC"
fi

echo "Run this once in the current shell to use it immediately:"
echo "  source ~/.bashrc"

#!/usr/bin/env bash
set -Eeuo pipefail

COMMAND="${1:-status}"
HOST_NAME="${KSP_PROD_SSH:-ksp@192.168.20.105}"
PROD_URL="${KSP_PROD_URL:-http://192.168.20.105:5173}"
BRANCH="${KSP_PROD_BRANCH:-main}"

SUDO_HELP="Prod sudo permissions may need to be refreshed. Run: bash scripts/prod deploy, then bash scripts/prod repair-sudo"

prod_ssh() {
  ssh "$HOST_NAME" "$@"
}

run_remote() {
  local command="$1"

  if ! prod_ssh "$command"; then
    echo
    echo "$SUDO_HELP"
    return 1
  fi
}

redeploy_remote() {
  run_remote "git --work-tree=/opt/ksp-control-panel/app --git-dir=/srv/git/ksp-control-panel.git checkout -f $BRANCH && cd /opt/ksp-control-panel/app && bash deploy/ubuntu/deploy.sh"
}

require_clean_deploy_tree() {
  local dirty

  dirty="$(git status --porcelain)"

  if [[ -n "$dirty" ]]; then
    echo "There are local changes that are not committed, so deploy would not include them."
    echo
    echo "$dirty"
    echo
    echo "Commit the changes first, then run: bash scripts/prod deploy"
    return 1
  fi
}

show_health() {
  python3 - "$PROD_URL/api/health" <<'PY'
import json
import sys
import urllib.request

url = sys.argv[1]
try:
    with urllib.request.urlopen(url, timeout=5) as response:
        health = json.load(response)
except Exception as exc:
    print(f"Backend health is unreachable at {url}")
    print(exc)
    raise SystemExit(1)

backend = "online" if health.get("ok") else "not ok"
mission = "active" if health.get("mission_active") else "idle"
action = health.get("action") or "none"
vessel = health.get("cached_vessel_name") or "none"
telemetry_age = health.get("telemetry_cache_age")
telemetry_label = f"{telemetry_age:.1f}s" if isinstance(telemetry_age, (int, float)) else "unknown"
krpc = health.get("krpc_connections") or {}
timing = health.get("telemetry_timing") or {}
uptime = int(health.get("uptime_seconds") or 0)

print(f"Backend:        {backend}")
print(f"Mission:        {mission}")
print(f"Action:         {action}")
print(f"Vessel:         {vessel}")
print(f"Telemetry age:  {telemetry_label}")
if timing:
    print(
        "TLM update:     "
        f"{timing.get('total_seconds', 0):.3f}s total, "
        f"{timing.get('slow_seconds', 0):.3f}s slow, "
        f"slow={timing.get('include_slow')}"
    )
print(f"kRPC streams:   {krpc.get('open_count', 'unknown')} open")
print(f"Uptime:         {uptime}s")
PY
}

show_mission() {
  python3 - "$PROD_URL/api/mission" <<'PY'
import json
import sys
import time
import urllib.request

url = sys.argv[1]
with urllib.request.urlopen(url, timeout=5) as response:
    payload = json.load(response)

mission = payload.get("mission") or {}
events = mission.get("events") or []

print(f"Active:   {mission.get('active')}")
print(f"Phase:    {mission.get('phase') or 'none'}")
print(f"Action:   {mission.get('action') or 'none'}")
print(f"Error:    {mission.get('last_error') or 'none'}")
print("Events:")

for event in events[-20:]:
    timestamp = event.get("time")
    clock = time.strftime("%H:%M:%S", time.localtime(timestamp)) if timestamp else "--:--:--"
    details = event.get("details") or {}
    detail_text = f" {details}" if details else ""
    print(f"  {clock} {event.get('phase') or '-'} {event.get('event')}{detail_text}")
PY
}

case "$COMMAND" in
  status)
    echo "Production health"
    show_health
    echo
    echo "Backend service"
    prod_ssh "/usr/bin/systemctl --no-pager --full status ksp-backend || true"
    ;;
  health)
    show_health
    ;;
  mission)
    show_mission
    ;;
  up)
    run_remote "sudo /usr/bin/systemctl restart ksp-backend && sudo /usr/sbin/nginx -t && sudo /usr/bin/systemctl reload nginx"
    show_health
    ;;
  down)
    prod_ssh "pkill -TERM -u ksp -f 'gunicorn.*main:app' || true"
    echo "Backend stopped. The frontend may still load, but API calls will be offline."
    ;;
  restart)
    run_remote "sudo /usr/bin/systemctl restart ksp-backend"
    show_health
    ;;
  reload)
    run_remote "sudo /usr/sbin/nginx -t && sudo /usr/bin/systemctl reload nginx"
    echo "Nginx reloaded."
    ;;
  logs)
    run_remote "sudo /usr/bin/journalctl -u ksp-backend -n 120 -f"
    ;;
  repair-sudo)
    run_remote "sudo /usr/local/sbin/ksp-control-panel-install-system-config"
    echo "Prod sudo permissions refreshed."
    ;;
  redeploy)
    redeploy_remote
    ;;
  deploy|update)
    require_clean_deploy_tree
    git push prod "HEAD:$BRANCH"
    redeploy_remote
    ;;
  ssh)
    ssh "$HOST_NAME"
    ;;
  *)
    echo "Usage: scripts/prod [status|health|mission|up|down|restart|reload|logs|repair-sudo|redeploy|deploy|update|ssh]"
    exit 2
    ;;
esac
